# DeepSeek 模型配置
DEEPSEEK_API_KEY='your_deepseek_api_key'
DEEPSEEK_BASE_URL='https://api.deepseek.com'

# Qwen 模型配置
QWEN_OMNI_API_KEY='your_qwen_api_key'
QWEN_OMNI_BASE_URL='https://dashscope.aliyuncs.com/compatible-mode/v1'

# Qwen 审查器模型配置（用于内容审查）
QWEN_API_KEY='your_qwen_api_key'
QWEN_BASE_URL='https://dashscope.aliyuncs.com/compatible-mode/v1'

# Tongyi Embedding 模型配置
TONGYI_EMBEDDING_API_KEY='your_tongyi_api_key'
TONGYI_EMBEDDING_BASE_URL='https://dashscope.aliyuncs.com/compatible-mode/v1'

# Embedding backend（M17）
# 可选值：sentence_transformers | dashscope
EMBEDDING_BACKEND='sentence_transformers'
# 若使用开源 embedding，默认模型如下；切换模型后建议重建 chroma_db
EMBEDDING_MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2'
# 模型缓存目录（容器/CI 推荐显式配置到可写路径）
EMBEDDING_CACHE_DIR='./.cache/huggingface'

# API 认证配置
API_KEY='your_api_key_here'

# Provider 密钥加密配置（用于存储 Provider API Key）
# 建议使用长度 >= 32 的随机字符串
PROVIDER_SECRET_KEY='replace_with_long_random_string'

# JWT 认证配置
JWT_SECRET_KEY='replace_with_long_random_string'
JWT_ALGORITHM='HS256'
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS 允许的来源 (逗号分隔)
ALLOWED_ORIGINS='http://localhost:3000,http://localhost:8501'

# PostgreSQL / Alembic 数据库连接，格式示例：
# DATABASE_URL='postgresql+asyncpg://user:pass@localhost:5432/hybrid_agent'
# 不设置则默认使用本地 SQLite `documents.db`
# (保持原有 SQLite 运行路径，未来阶段 M3 可切换）

# MySQL 数据库配置 (可选，当前默认使用 SQLite)
# MYSQL_USER=your_mysql_user
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=hybrid_agent

# 监控与日志配置（M7：structlog + Prometheus）
LOG_LEVEL='INFO'
# 通过 `structlog.configure` 读取此 env 以调整全局输出格式
STRUCTLOG_PRETTY='true'  # 可选：true 以启用带颜色的输出

# Prometheus FastAPI Instrumentator 配置
PROMETHEUS_METRICS_PATH='/metrics'
# Instrumentator 可选地写入多进程目录，若不使用无需设置
# PROMETHEUS_MULTIPROC_DIR='/tmp/hybrid-agent-prometheus'
PROMETHEUS_EXPORTER_PORT=8000

# 说明：在启动脚本中使用 `Instrumentator().instrument(app).expose(app)` 可将
# `/metrics` 暴露给 Prometheus，structlog 通过上述 LOG_LEVEL/STRUCTLOG_PRETTY 进行格式切换。
